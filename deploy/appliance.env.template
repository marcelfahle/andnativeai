# &native.ai appliance environment — rendered by scripts/provision-appliance.sh
# Keep this file at the appliance root with mode 600; it holds every secret
# the appliance needs.

# --- Identity -------------------------------------------------------------
PHX_HOST=__DOMAIN__
PORT=4000

# --- Generated secrets (unique per appliance) ------------------------------
SECRET_KEY_BASE=__SECRET_KEY_BASE__
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
MINIO_ROOT_PASSWORD=__MINIO_ROOT_PASSWORD__
# Encrypts Slack tokens / OAuth secrets at rest (AES-256-GCM).
CLOAK_KEY=__CLOAK_KEY__

# --- First admin (seeded on first boot; rotate after first login) ----------
SEED_ADMIN_EMAIL=__ADMIN_EMAIL__
SEED_ADMIN_PASSWORD=__ADMIN_PASSWORD__

# --- Platform staff (superadmins; hidden from customer user management) -----
SEED_PLATFORM1_EMAIL=__PLATFORM1_EMAIL__
SEED_PLATFORM1_PASSWORD=__PLATFORM1_PASSWORD__
SEED_PLATFORM2_EMAIL=__PLATFORM2_EMAIL__
SEED_PLATFORM2_PASSWORD=__PLATFORM2_PASSWORD__

# --- Build ------------------------------------------------------------------
# Repo checkout the appliance images build from.
REPO_DIR=__REPO_DIR__
# External Docker network Caddy shares with appliances.
CADDY_NETWORK=__CADDY_NETWORK__

# --- Providers (fill in per customer) ---------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# GEMINI_API_KEY=

# --- Slack (per-workspace app; configure via /admin/slack OAuth) ------------
# SLACK_APP_TOKEN=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
